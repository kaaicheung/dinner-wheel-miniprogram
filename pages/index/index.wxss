.page {
  min-height: 100vh;
  padding: 24rpx 32rpx 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  background:
    radial-gradient(120% 80% at 50% -10%, rgba(255, 107, 53, 0.18), transparent 60%),
    #1a1424;
}

.header {
  text-align: center;
  margin-top: 8rpx;
}
.title {
  font-size: 52rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  color: #ffd23f;
}
.subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: rgba(250, 243, 230, 0.6);
}

/* Tabs */
.tabs {
  width: 100%;
  margin: 32rpx 0 20rpx;
  white-space: nowrap;
}
.tabs-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 4rpx;
}
.tab {
  display: inline-block;
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: rgba(250, 243, 230, 0.75);
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  transition: all 0.18s ease;
}
.tab--active {
  color: #1a1424;
  background: #ffd23f;
  border-color: #ffd23f;
  font-weight: 700;
}

/* Wheel */
.wheel-wrap {
  position: relative;
  width: 640rpx;
  height: 640rpx;
  margin: 24rpx 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.wheel-canvas {
  width: 640rpx;
  height: 640rpx;
}
.pointer {
  position: absolute;
  top: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 26rpx solid transparent;
  border-right: 26rpx solid transparent;
  border-top: 42rpx solid #ff6b35;
  filter: drop-shadow(0 4rpx 6rpx rgba(0, 0, 0, 0.4));
  z-index: 5;
}
.spin-btn {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 168rpx;
  height: 168rpx;
  border-radius: 50%;
  background: linear-gradient(160deg, #ff8a4c, #ff5722);
  box-shadow: 0 8rpx 24rpx rgba(255, 87, 34, 0.45), inset 0 -6rpx 12rpx rgba(0,0,0,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 4;
  border: 6rpx solid #faf3e6;
}
.spin-btn--busy { opacity: 0.85; }
.spin-btn__text {
  color: #fff;
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

/* Result */
.result {
  width: 100%;
  max-width: 620rpx;
  margin-top: 28rpx;
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(255, 210, 63, 0.25);
  text-align: center;
  opacity: 0.5;
  transform: translateY(10rpx);
  transition: all 0.28s ease;
}
.result--show {
  opacity: 1;
  transform: translateY(0);
  background: rgba(255, 210, 63, 0.08);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.35);
}
.result__hint {
  font-size: 28rpx;
  color: rgba(250, 243, 230, 0.6);
  line-height: 1.6;
}
.result__label {
  font-size: 26rpx;
  color: rgba(250, 243, 230, 0.6);
  letter-spacing: 4rpx;
}
.result__name {
  margin-top: 10rpx;
  font-size: 60rpx;
  font-weight: 800;
  color: #ffd23f;
}
.result__cuisine {
  margin-top: 8rpx;
  display: inline-block;
  padding: 6rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #ff6b35;
  background: rgba(255, 107, 53, 0.14);
}
.result__line {
  margin-top: 18rpx;
  font-size: 30rpx;
  color: #faf3e6;
}
.result__again {
  margin-top: 26rpx;
  display: inline-block;
  padding: 18rpx 48rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1424;
  background: #ffd23f;
}

/* Confetti */
.confetti {
  position: fixed;
  left: 0; right: 0; top: 0;
  height: 100vh;
  pointer-events: none;
  z-index: 50;
  overflow: hidden;
}
.confetti__bit {
  position: absolute;
  top: -20rpx;
  width: 16rpx;
  height: 26rpx;
  border-radius: 3rpx;
  opacity: 0;
}
.confetti--go .confetti__bit {
  animation: fall 1.8s ease-in forwards;
}
@keyframes fall {
  0% { opacity: 1; transform: translateY(-20rpx) rotate(0deg); }
  100% { opacity: 0; transform: translateY(105vh) rotate(520deg); }
}
